# ============================================================
# Battle Trade — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in your values.
# Lines marked [required] must be set for the app to run.
# Lines marked [optional] enable extra features when provided.
# ============================================================

# ----------------------------------------------------------
# Supabase  [required]
# ----------------------------------------------------------
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ----------------------------------------------------------
# Authentication — Privy  [required]
# ----------------------------------------------------------
NEXT_PUBLIC_PRIVY_APP_ID=your_privy_app_id_here

# ----------------------------------------------------------
# Admin  [optional — falls back to per-lobby passwords]
# ----------------------------------------------------------
# Global admin password for all lobbies
ADMIN_PASSWORD=your_admin_password_here

# ----------------------------------------------------------
# App URLs  [optional — defaults shown]
# ----------------------------------------------------------
# Used for OG meta tags and SEO
NEXT_PUBLIC_BASE_URL=https://battletrade.gg
# Used for registration links in emails
NEXT_PUBLIC_APP_URL=https://battle.fyi

# ----------------------------------------------------------
# Payments — Stripe  [optional]
# ----------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# ----------------------------------------------------------
# Payments — Coinbase Commerce  [optional]
# ----------------------------------------------------------
COINBASE_COMMERCE_API_KEY=your_coinbase_commerce_api_key_here
COINBASE_WEBHOOK_SECRET=your_coinbase_webhook_secret_here

# ----------------------------------------------------------
# Email — Resend  [optional]
# ----------------------------------------------------------
RESEND_API_KEY=re_your_resend_api_key_here
FROM_EMAIL=Battle Trade <noreply@battletrade.gg>

# ----------------------------------------------------------
# DEX / Trading  [optional]
# ----------------------------------------------------------
# Generic DEX adapter for live order routing
LIVE_DEX_API_URL=https://api.example.com
LIVE_DEX_API_KEY=your_dex_api_key_here

# Hyperliquid perpetuals adapter
HYPERLIQUID_PRIVATE_KEY=0x_your_private_key_here
HYPERLIQUID_TESTNET=true

# ----------------------------------------------------------
# Wallet  [optional]
# ----------------------------------------------------------
# Platform wallet address for on-chain escrow / payouts
PLATFORM_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# ----------------------------------------------------------
# Exchange Key Encryption  [optional]
# ----------------------------------------------------------
# 32-byte hex key (64 chars) for encrypting stored exchange API keys
EXCHANGE_ENCRYPTION_KEY=your_64_char_hex_string_here

# ----------------------------------------------------------
# Streaming — Mux  [optional — pick one provider]
# ----------------------------------------------------------
# Set to "mux" or "cloudflare"; auto-detected from available keys if omitted
STREAMING_PROVIDER=mux
MUX_TOKEN_ID=your_mux_token_id_here
MUX_TOKEN_SECRET=your_mux_token_secret_here

# ----------------------------------------------------------
# Streaming — Cloudflare Stream  [optional]
# ----------------------------------------------------------
# STREAMING_PROVIDER=cloudflare
CF_STREAM_API_TOKEN=your_cloudflare_stream_api_token_here
CF_ACCOUNT_ID=your_cloudflare_account_id_here

# ----------------------------------------------------------
# Analytics — PostHog  [optional]
# ----------------------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=phc_your_posthog_key_here
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# ----------------------------------------------------------
# Error Tracking — Sentry  [optional]
# ----------------------------------------------------------
NEXT_PUBLIC_SENTRY_DSN=https://your_key@o0.ingest.sentry.io/0
